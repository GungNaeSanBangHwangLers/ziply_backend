# MySQL 설정
MYSQL_ROOT_PASSWORD=your_mysql_password_here

# JWT Secret (최소 32자 이상)
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_VALIDITY=3600000
JWT_REFRESH_TOKEN_VALIDITY=1209600000

# API Keys
KAKAO_API_KEY=your_kakao_api_key
BUS_API_KEY=your_bus_api_key
ODSAY_API_KEY=your_odsay_api_key
SEOUL_TRAFFIC_API_KEY=your_seoul_traffic_api_key

# Google OAuth
GOOGLE_ANDROID_CLIENT_ID=your_google_client_id

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string
AZURE_STORAGE_CONTAINER_NAME=your_container_name

# Docker
DOCKER_USERNAME=your_docker_username

